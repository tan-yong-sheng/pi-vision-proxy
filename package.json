{
  "name": "pi-vision-proxy",
  "version": "1.6.0",
  "description": "Automatic image description for any model in Pi. Routes images to a vision model and injects descriptions into context.",
  "keywords": [
    "pi-package"
  ],
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/pungggi/pi-vision-proxy.git"
  },
  "homepage": "https://github.com/pungggi/pi-vision-proxy#readme",
  "type": "module",
  "scripts": {
    "test": "node --experimental-strip-types --no-warnings --test extensions/__tests__/*.test.ts"
  },
  "pi": {
    "extensions": [
      "./extensions/vision-proxy.ts"
    ]
  },
  "dependencies": {
    "image-size": "^2.0.2",
    "imagescript": "^1.3.1",
    "imghash": "^1.1.4"
  },
  "peerDependencies": {
    "@earendil-works/pi-ai": ">=0.74.0",
    "@earendil-works/pi-coding-agent": ">=0.74.0",
    "typebox": "*"
  }
}
